---
import AudioControl from '../components/AudioControl.astro';
import StarfieldCanvas from '../components/StarfieldCanvas.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  active?: 'home' | 'blog' | 'projects';
}

const {
  title = 'ZDHUA-Blog | 个人作品集与技术博客',
  description = 'ZDHUA-Blog 是一个个人作品集与技术博客，记录前端、部署、AI 工具、自动化和界面实验。',
  active = 'home',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://zdhua.me');
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#030406" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <StarfieldCanvas />
    <a class="skip-link" href="#main">跳到正文</a>
    <div class="scan-grid" aria-hidden="true"></div>
    <header class="site-header">
      <a class="brand" href="/" aria-label="ZDHUA-Blog 首页">
        <span class="brand-mark" aria-hidden="true">Z</span>
        <span>ZDHUA-Blog</span>
      </a>
      <nav class="site-nav" aria-label="主导航">
        <a href="/" aria-current={active === 'home' ? 'page' : undefined}>首页</a>
        <a href="/projects/" aria-current={active === 'projects' ? 'page' : undefined}>项目</a>
        <a href="/blog/" aria-current={active === 'blog' ? 'page' : undefined}>文章</a>
        <a href="https://github.com/ZDHUA00" rel="noreferrer">仓库</a>
      </nav>
      <AudioControl />
    </header>
    <slot />
    <footer class="site-footer">
      <span>ZDHUA-Blog</span>
      <span>域名：zdhua.me</span>
      <span>Astro Sphere 风格改造 · Astro + 原生 JS/CSS</span>
    </footer>
    <script type="module" src="/scripts/console.js"></script>
  </body>
</html>
