---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'ZDHUA.LOG',
  description = 'ZDHUA.LOG 是一个科幻视觉风格的个人博客，记录工程、自动化、服务器和 AI 工具链。',
} = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#07080d" />
    <title>{title}</title>
    <link rel="preload" href={`${base}assets/nebula-field.png`} as="image" />
  </head>
  <body>
    <canvas class="star-canvas" id="starCanvas" aria-hidden="true"></canvas>
    <div class="cursor-glow" id="cursorGlow" aria-hidden="true"></div>
    <header class="site-header">
      <a class="brand" href={`${base}`} aria-label="ZDHUA.LOG 首页">
        <span class="brand-mark" aria-hidden="true"></span>
        <span>ZDHUA.LOG</span>
      </a>
      <nav class="site-nav" aria-label="主导航">
        <a href={`${base}#archive`}>文章</a>
        <a href={`${base}blog/`}>归档</a>
        <a href={`${base}#lab`}>实验室</a>
        <a href={`${base}#timeline`}>时间线</a>
      </nav>
      <button class="icon-button" id="themeToggle" type="button" aria-label="切换显示模式" title="切换显示模式">
        <span class="theme-icon" aria-hidden="true"></span>
      </button>
    </header>
    <slot />
    <footer class="site-footer">
      <span>ZDHUA.LOG</span>
      <span>Astro + native JS/CSS</span>
    </footer>
    <script src={`${base}scripts/blog.js`} defer></script>
  </body>
</html>
