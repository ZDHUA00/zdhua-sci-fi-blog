---
import AudioControl from '../components/AudioControl.astro';
import StarfieldCanvas from '../components/StarfieldCanvas.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  active?: 'home' | 'blog';
}

const {
  title = 'ZDHUA.LOG | 星际舰船档案控制台',
  description = 'ZDHUA 的个人博客，记录部署、自动化、AI 工具与界面实验。',
  active = 'home',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://zdhua.me');
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#070a0c" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <StarfieldCanvas />
    <a class="skip-link" href="#main">跳到正文</a>
    <div class="scan-grid" aria-hidden="true"></div>
    <header class="site-header">
      <a class="brand" href="/" aria-label="ZDHUA.LOG 首页">
        <span class="brand-mark" aria-hidden="true">Z</span>
        <span>ZDHUA.LOG</span>
      </a>
      <nav class="site-nav" aria-label="主导航">
        <a href="/" aria-current={active === 'home' ? 'page' : undefined}>舰桥</a>
        <a href="/blog/" aria-current={active === 'blog' ? 'page' : undefined}>档案</a>
        <a href="https://github.com/ZDHUA00" rel="noreferrer">GitHub</a>
      </nav>
      <AudioControl />
    </header>
    <slot />
    <footer class="site-footer">
      <span>ZDHUA.LOG</span>
      <span>Custom domain: zdhua.me</span>
      <span>Astro + native JS/CSS</span>
    </footer>
    <script type="module" src="/scripts/console.js"></script>
  </body>
</html>
