---
interface Props {
  signal?: string;
  category?: string;
  class?: string;
}

const {
  signal = 'ZDHUA',
  category = 'Deploy',
  class: className = '',
} = Astro.props;

const categorySlug = category.toLowerCase().replace(/[^a-z0-9-]/g, '') || 'deploy';
---

<span
  class:list={['signal-art', `signal-art-${categorySlug}`, className]}
  data-signal={signal}
  data-category={category}
  aria-hidden="true"
>
  <span class="signal-art-grid"></span>
  <span class="signal-art-nebula"></span>
  <span class="signal-art-horizon"></span>
  <span class="signal-art-ring signal-art-ring-one"></span>
  <span class="signal-art-ring signal-art-ring-two"></span>
  <span class="signal-art-ring signal-art-ring-three"></span>
  <span class="signal-art-core"></span>
  <span class="signal-art-beam signal-art-beam-one"></span>
  <span class="signal-art-beam signal-art-beam-two"></span>
  <span class="signal-art-scan"></span>
</span>
