<div class="audio-dock" data-audio-dock>
  <button class="audio-trigger" type="button" data-audio-toggle aria-expanded="false" aria-controls="audio-panel" title="音乐播放器">
    <span class="audio-trigger__icon" aria-hidden="true"></span>
    <span class="audio-trigger__text">音乐</span>
  </button>
  <div class="audio-panel" id="audio-panel" data-audio-panel hidden>
    <div class="audio-panel__top">
      <strong>背景音乐</strong>
      <span data-audio-state>待播放</span>
    </div>
    <canvas class="audio-scope" width="320" height="64" data-audio-scope aria-hidden="true"></canvas>
    <div class="audio-now">
      <span data-audio-track-name>星河慢放</span>
      <b data-audio-beat>00:00</b>
    </div>
    <div class="audio-controls">
      <button class="console-button" type="button" data-audio-play>播放</button>
      <label class="range-field">
        <span>音量 <b data-audio-volume-readout>180%</b></span>
        <input type="range" data-audio-volume min="0" max="350" value="180" />
      </label>
      <label class="select-field">
        <span>曲目</span>
        <select data-audio-track>
          <option value="starlight">星河慢放</option>
          <option value="night">夜航节拍</option>
          <option value="piano">轨道钢琴</option>
        </select>
      </label>
    </div>
  </div>
</div>
