---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostSignal from '../../components/PostSignal.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const tags = Array.from(new Set(posts.flatMap((post) => post.data.tags))).sort();
---

<BaseLayout
  active="blog"
  title="文章 | ZDHUA-Blog"
  description="ZDHUA-Blog 的技术文章、项目日志、部署记录和界面实验。"
>
  <main id="main">
    <section class="archive-hero">
      <h1>文章</h1>
      <p>这里记录站点迭代、项目实验、前端设计、部署流程和 AI 辅助开发经验。</p>
    </section>

    <section class="filter-bar" data-filter-bar aria-label="文章筛选">
      <button type="button" class="filter-chip is-active" data-filter="all">全部</button>
      {tags.map((tag) => <button type="button" class="filter-chip" data-filter={tag}>{tag}</button>)}
    </section>

    <section class="archive-list" data-archive-list>
      {posts.map((post) => (
        <article class={`archive-row archive-row--${post.data.accent}`} data-tags={post.data.tags.join('|')}>
          <a href={`/blog/${post.slug}/`}>
            <PostSignal seed={post.slug} accent={post.data.accent} intensity={post.data.intensity} />
            <div class="archive-row__body">
              <div class="archive-row__meta">
                <span>{post.data.channel}</span>
                <span>{post.data.status}</span>
                <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString('zh-CN')}</time>
              </div>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              <div class="tag-line">
                {post.data.tags.map((tag) => <span>{tag}</span>)}
              </div>
            </div>
            <span class="read-time">{post.data.readTime}</span>
          </a>
        </article>
      ))}
    </section>
  </main>
</BaseLayout>
