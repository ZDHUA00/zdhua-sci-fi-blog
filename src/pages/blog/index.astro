---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="文章归档 | ZDHUA.LOG" description="ZDHUA.LOG 的全部文章归档。">
  <main class="page-shell">
    <section class="page-hero">
      <h1>文章归档</h1>
      <p>全部日志按时间倒序排列。每篇文章都是一条可追踪的工程信号，包含部署、服务器、自动化、AI 工具链和界面实验。</p>
    </section>
    <section class="archive-grid-page" aria-label="全部文章">
      {posts.map((post, index) => (
        <a class="post-tile" href={`${base}blog/${post.slug}/`}>
          <img src={`${base}${post.data.cover}`} alt={post.data.coverAlt} loading={index < 2 ? 'eager' : 'lazy'} />
          <span class="signal-line">{post.data.signal} / {post.data.category}</span>
          <h2>{post.data.title}</h2>
          <p>{post.data.description}</p>
          <span class="card-meta">
            <span>{post.data.date.toISOString().slice(0, 10)}</span>
            <span>{post.data.readTime}</span>
            {post.data.tags.slice(0, 2).map((tag) => <span>{tag}</span>)}
          </span>
        </a>
      ))}
    </section>
  </main>
</BaseLayout>
