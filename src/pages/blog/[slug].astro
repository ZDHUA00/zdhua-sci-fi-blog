---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
---

<BaseLayout title={`${post.data.title} | ZDHUA.LOG`} description={post.data.description}>
  <main class="article-shell">
    <div class="read-progress" id="readProgress" aria-hidden="true"></div>
    <article class="article-page">
      <header class="article-header">
        <span class="signal-line">{post.data.signal} / {post.data.category} / {post.data.readTime}</span>
        <h1>{post.data.title}</h1>
        <p>{post.data.description}</p>
        <div class="reader-tags">
          {post.data.tags.map((tag) => <span>{tag}</span>)}
        </div>
      </header>
      <div class="article-body">
        <Content />
      </div>
    </article>
    <aside class="toc-panel" aria-label="文章目录">
      <strong>目录</strong>
      {headings.length ? (
        <nav>
          {headings.map((heading) => (
            <a href={`#${heading.slug}`}>{heading.text}</a>
          ))}
        </nav>
      ) : (
        <p>暂无目录</p>
      )}
      <a class="reader-link" href={`${import.meta.env.BASE_URL}blog/`}>返回归档</a>
    </aside>
  </main>
</BaseLayout>
