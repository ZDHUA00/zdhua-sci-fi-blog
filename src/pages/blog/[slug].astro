---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostSignal from '../../components/PostSignal.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  active="blog"
  title={`${post.data.title} | ZDHUA-Blog`}
  description={post.data.description}
>
  <main id="main">
    <article class={`article-shell article-shell--${post.data.accent}`}>
      <header class="article-hero">
        <a class="back-link" href="/blog/">返回文章列表</a>
        <div class="article-hero__grid">
          <div>
            <div class="article-meta">
              <span>{post.data.channel}</span>
              <span>{post.data.status}</span>
              <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString('zh-CN')}</time>
            </div>
            <h1>{post.data.title}</h1>
            <p>{post.data.description}</p>
            <div class="tag-line">
              {post.data.tags.map((tag) => <span>{tag}</span>)}
            </div>
          </div>
          <PostSignal
            seed={post.slug}
            accent={post.data.accent}
            intensity={post.data.intensity}
            label={`${post.data.title} signal visual`}
          />
        </div>
      </header>
      <div class="article-content">
        <Content />
      </div>
    </article>
  </main>
</BaseLayout>
