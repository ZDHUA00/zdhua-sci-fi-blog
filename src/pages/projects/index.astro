---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { projects } from '../../data/projects';
---

<BaseLayout
  active="projects"
  title="Projects | ZDHUA-Blog"
  description="ZDHUA-Blog 的项目、实验和部署记录。"
>
  <main id="main">
    <section class="archive-hero">
      <h1>Projects</h1>
      <p>这里放个人项目、界面实验、部署记录和后续会继续扩展的作品集。</p>
    </section>

    <section class="project-grid">
      {projects.map((project) => (
        <article class={`project-card project-card--${project.accent}`}>
          <div class="project-card__top">
            <span>{project.status}</span>
            <strong>{project.year}</strong>
          </div>
          <h2>{project.title}</h2>
          <p>{project.description}</p>
          <div class="tag-line">
            {project.stack.map((item) => <span>{item}</span>)}
          </div>
          <a href={project.href}>打开</a>
        </article>
      ))}
    </section>
  </main>
</BaseLayout>
