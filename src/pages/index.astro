---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostSignal from '../components/PostSignal.astro';
import { projects } from '../data/projects';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recentPosts = posts.slice(0, 3);
const recentProjects = projects.slice(0, 3);
---

<BaseLayout active="home">
  <main id="main">
    <section class="sphere-hero" data-console-tilt>
      <div class="planet-crescent" aria-hidden="true">
        <div class="planet-glow"></div>
      </div>
      <div class="sphere-hero__content">
        <p class="hero-intro">Hello, I am building</p>
        <h1>ZDHUA-Blog</h1>
        <p class="hero-subtitle">
          一个个人作品集与技术博客，记录前端开发、网站部署、AI 工具、自动化流程和带一点深空感的界面实验。
        </p>
        <div class="hero__actions">
          <a class="primary-action" href="/blog/">Read the blog</a>
          <a class="secondary-action" href="/projects/">View projects</a>
        </div>
      </div>
    </section>

    <div class="sphere-content">
      <section class="profile-section">
        <p>
          我是 ZDHUA，正在把这个站点打造成一个长期维护的个人主页。这里不会只放普通文章列表，也会记录我做过的项目、部署经验、工具实验和界面设计想法。
        </p>
        <p>
          这个版本采用 <strong>Astro Sphere</strong> 的开源思路：轻量、现代、个人品牌优先。视觉上保留黑色星空、轨道、信号图和 BGM 控制，但页面结构会更像成熟作品集。
        </p>
      </section>

      <section class="list-section">
        <div class="section-heading">
          <h2>Recent posts</h2>
          <a href="/blog/">All posts</a>
        </div>
        <div class="arrow-list">
          {recentPosts.map((post) => (
            <a class="arrow-card" href={`/blog/${post.slug}/`}>
              <span>{post.data.channel}</span>
              <div>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
              </div>
              <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString('zh-CN')}</time>
            </a>
          ))}
        </div>
      </section>

      <section class="stack-section">
        <h2>Website built with</h2>
        <div class="stack-grid">
          <span>Astro</span>
          <span>Markdown</span>
          <span>Native JS</span>
          <span>CSS Motion</span>
          <span>GitHub Pages</span>
          <span>zdhua.me</span>
        </div>
      </section>

      <section class="list-section">
        <div class="section-heading">
          <h2>Recent projects</h2>
          <a href="/projects/">All projects</a>
        </div>
        <div class="project-preview-grid">
          {recentProjects.map((project) => (
            <article class={`project-card project-card--${project.accent}`}>
              <div class="project-card__top">
                <span>{project.status}</span>
                <strong>{project.year}</strong>
              </div>
              <h3>{project.title}</h3>
              <p>{project.description}</p>
              <div class="tag-line">
                {project.stack.map((item) => <span>{item}</span>)}
              </div>
              <a href={project.href}>查看项目</a>
            </article>
          ))}
        </div>
      </section>

      <section class="visual-section">
        <div>
          <h2>Signal visual system</h2>
          <p>
            每篇文章仍然保留独立的信号图，但它现在是作品集体系的一部分，而不是单纯装饰。后续可以继续扩展成项目封面、技术栈标识和搜索动效。
          </p>
        </div>
        <PostSignal seed="zdhua-blog-sphere" accent="green" intensity={78} />
      </section>
    </div>
  </main>
</BaseLayout>
