---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostSignal from '../components/PostSignal.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featured = posts.slice(0, 3);
---

<BaseLayout active="home">
  <main id="main">
    <section class="hero" data-console-tilt>
      <div class="hero__copy">
        <h1>ZDHUA.LOG</h1>
        <p>
          一座面向个人技术记录的星际舰船控制台。部署、自动化、AI 工具、界面实验都被整理成可扫描的航行日志。
        </p>
        <div class="hero__actions">
          <a class="primary-action" href="/blog/">打开档案舱</a>
          <a class="secondary-action" href="#latest">查看最新信号</a>
        </div>
      </div>

      <div class="cockpit" aria-label="星舰控制台状态">
        <div class="cockpit__viewport">
          <div class="reticle" aria-hidden="true"></div>
          <div class="trajectory trajectory--one" aria-hidden="true"></div>
          <div class="trajectory trajectory--two" aria-hidden="true"></div>
          <div class="cockpit__readout">
            <span>ORBIT</span>
            <strong>zdhua.me</strong>
          </div>
        </div>
        <div class="cockpit__rail">
          <span>CORE</span>
          <b>97%</b>
          <span>SYNC</span>
          <b>ACTIVE</b>
          <span>BUILD</span>
          <b>ASTRO</b>
        </div>
      </div>
    </section>

    <section class="systems">
      <div class="system-panel system-panel--green">
        <span>01</span>
        <h2>轻量星域</h2>
        <p>Canvas 限制 DPR 和帧率，页面隐藏时暂停，移动端减少粒子数量。</p>
      </div>
      <div class="system-panel system-panel--amber">
        <span>02</span>
        <h2>隐藏广播</h2>
        <p>顶部下拉式 BGM，Web Audio 合成音轨，音量上限提升到 500%。</p>
      </div>
      <div class="system-panel system-panel--magenta">
        <span>03</span>
        <h2>动态档案</h2>
        <p>每篇文章用种子生成独立信号图，不依赖单调静态封面。</p>
      </div>
    </section>

    <section class="latest" id="latest">
      <div class="section-heading">
        <h2>最新航行日志</h2>
        <a href="/blog/">全部档案</a>
      </div>
      <div class="latest-grid">
        {featured.map((post) => (
          <article class={`log-card log-card--${post.data.accent}`} data-log-card>
            <a href={`/blog/${post.slug}/`} aria-label={`阅读 ${post.data.title}`}>
              <PostSignal seed={post.slug} accent={post.data.accent} intensity={post.data.intensity} />
              <div class="log-card__body">
                <div class="log-card__meta">
                  <span>{post.data.channel}</span>
                  <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString('zh-CN')}</time>
                </div>
                <h3>{post.data.title}</h3>
                <p>{post.data.description}</p>
              </div>
            </a>
          </article>
        ))}
      </div>
    </section>

    <section class="manifest">
      <div>
        <h2>重建目标</h2>
        <p>
          保留 GitHub Pages 与自定义域名，把博客重新做成一台有层次的舰船操作界面：先有视觉冲击，再保证阅读、筛选、播放和移动端都顺滑。
        </p>
      </div>
      <a class="primary-action" href="/blog/">进入日志索引</a>
    </section>
  </main>
</BaseLayout>
